# Flask / Gunicorn
PORT=5000
FLASK_DEBUG=false

# App secrets
JWT_SECRET_KEY=change-this-to-a-long-random-secret
# Optional: set temporarily if you need to create admin accounts through /api/register.
ADMIN_REGISTRATION_CODE=

# MySQL - local/development names used by the app
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=comp3161_project

# MySQL - Railway can also provide DATABASE_URL, MYSQL_URL, or MYSQL* variables.
# Do not commit real credentials.
# DATABASE_URL=mysql://user:password@host:3306/database
# MYSQLHOST=
# MYSQLPORT=3306
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=

# Redis
REDIS_URL=redis://localhost:6379
